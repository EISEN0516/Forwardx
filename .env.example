# ForwardX 端口转发管理面板 - 环境变量配置
# 复制此文件为 .env 并修改对应值

# ==================== 数据库配置 ====================
# SQLite 数据库文件路径（Docker 部署时挂载到 /data 目录）
SQLITE_PATH=/data/forwardx.db

# ==================== 安全配置 ====================
# JWT 签名密钥（生产环境务必修改为随机字符串）
JWT_SECRET=change-me-to-a-random-string

# ==================== 应用配置 ====================
# 运行环境
NODE_ENV=production

# 监听端口
PORT=9810

# SSO 版本使用轻量派生镜像；基础镜像仍固定为官方 ForwardX v2.3.243。
# 在开发机执行 pnpm build 后构建此镜像，低配置服务器无需编译完整源码。
FORWARDX_IMAGE=forwardx-xboard:v2.3.243-sso.1
FORWARDX_BASE_IMAGE=ghcr.io/poouo/forwardx:v2.3.243

# ==================== Xboard 管理员单点登录 ====================
# 首次部署先保持 XBOARD_SSO_ONLY=false。确认 Xboard 入口登录成功后再改为 true。
XBOARD_SSO_ENABLED=true
XBOARD_SSO_ONLY=false
XBOARD_SSO_ISSUER=https://xb.senlimm.top
XBOARD_SSO_AUDIENCE=forwardx
XBOARD_SSO_KEY_ID=xboard-main-2026

# 必须填写 ForwardX 数据库中已经存在、已启用且 role=admin 的完整用户名。
XBOARD_SSO_FORWARDX_USERNAME=admin@example.com

# 公钥在宿主机上的路径。私钥只能保存在 Xboard 侧，禁止挂载到 ForwardX。
XBOARD_SSO_PUBLIC_KEY_HOST_PATH=./secrets/xboard-sso-public.pem

# SSO_ONLY 开启后，直接访问 ForwardX /login 时跳回这里。
XBOARD_LOGIN_URL=https://xb.senlimm.top

# ==================== Telegram 机器人（可选） ====================
# 从 @BotFather 获取 Bot Token。也可以登录后台后在「系统设置」中填写。
# TELEGRAM_BOT_TOKEN=123456789:replace-with-your-bot-token
# 是否启用长轮询。默认 true，不需要配置 webhook。
# TELEGRAM_BOT_POLLING=true

# ==================== 默认管理员账户 ====================
# 每次启动时 admin 密码会自动重置为此值（默认 admin123）
# 如需自定义默认密码，取消注释并修改下面的值
# ADMIN_PASSWORD=admin123
